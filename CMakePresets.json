{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 19,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "DISPATCH_WITH_TESTS": "OFF"
      }
    },
    {
      "name": "tests",
      "displayName": "Tests",
      "binaryDir": "${sourceDir}/build-tests",
      "cacheVariables": {
        "DISPATCH_WITH_TESTS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default"
    },
    {
      "name": "tests",
      "configurePreset": "tests"
    },
    {
      "name": "check",
      "configurePreset": "tests",
      "targets": [
        "check"
      ]
    }
  ],
  "testPresets": [
    {
      "name": "tests",
      "configurePreset": "tests",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
